event:world_start {
    if variable_exists(last_player_joined:SAVED) {
        send_message(last_player_joined:SAVED)
    }
}

event:player_join {
    send_message("Hello, <gold>%source%</gold>!":MINI_MESSAGE)
    send_message("Last player joined was:":MINI_MESSAGE)
    send_message(last_player_joined:SAVED)
}